GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL_EXTRACTION=gemini-2.5-flash
GEMINI_MODEL_EXTRACTION_COMPLEX=gemini-3-flash-preview
# Optional comma-separated form types to route to GEMINI_MODEL_EXTRACTION_COMPLEX.
# Example: consolidated-brokerage-statement,ssa-1099
GEMINI_COMPLEX_EXTRACTION_TYPES=
MAX_RETRIES=7
INITIAL_RETRY_DELAY=1.0
MAX_RETRY_DELAY=120.0
# Optional comma-separated extra CORS origins for production frontend URLs.
# Localhost origins are always allowed by default.
ALLOWED_ORIGINS=

# Optional pricing for estimated costs (USD per 1M tokens)
INPUT_COST_PER_MILLION=
OUTPUT_COST_PER_MILLION=
